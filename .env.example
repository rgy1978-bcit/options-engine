# ── App ──────────────────────────────────────────────────────────────────────
VITE_APP_ID=your-app-id

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=a-long-random-secret-string
OAUTH_SERVER_URL=https://your-oauth-server/
OWNER_OPEN_ID=your-owner-open-id

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI / Market Data ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your-google-gemini-key
FMP_API_KEY=your-financial-modeling-prep-key         # https://financialmodelingprep.com/

# Polygon.io — free tier gives 15-min delayed stock quotes used as fallback
# when FMP is unavailable. Paid plan ($29/mo) adds real-time + options chains.
# Sign up at https://polygon.io/ — leave blank to skip Polygon and fall through to Yahoo Finance.
POLYGON_API_KEY=

# Alpaca Markets — NOT wired up yet (broker enum stub only, no API calls).
# Fill in when ready to build broker connection + order execution features.
# https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Alpha Vantage — intentionally excluded. It has no options chain data, no IV,
# and no Greeks. FMP covers everything Alpha Vantage does for this app, better.
# ALPHA_VANTAGE_API_KEY=  (do not add — not used)

# ── Notifications (optional) ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Internal (set by platform, not needed locally) ───────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
